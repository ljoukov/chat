{
  "name": "@ljoukov/chat",
  "version": "0.1.1",
  "description": "Composable Svelte chat UI components with markdown rendering, status cards, and reusable thread layouts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ljoukov/chat.git"
  },
  "bugs": {
    "url": "https://github.com/ljoukov/chat/issues"
  },
  "homepage": "https://github.com/ljoukov/chat#readme",
  "author": "Liudmila Joukovskaya",
  "type": "module",
  "workspaces": [
    "examples/*"
  ],
  "scripts": {
    "dev": "npm run dev:gallery",
    "dev:gallery": "node ./scripts/run-gallery-dev.mjs",
    "gallery:debug": "node ./scripts/capture-gallery-debug.mjs",
    "docs:screenshots": "node ./scripts/capture-readme-screenshots.mjs",
    "build": "svelte-kit sync && svelte-package && publint",
    "build:examples": "npm run build --workspace @ljoukov/chat-gallery",
    "preview:gallery": "npm run preview --workspace @ljoukov/chat-gallery",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "npm run verify",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "check:examples": "npm run check --workspace @ljoukov/chat-gallery",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test": "npm run test:unit",
    "verify": "npm run lint && npm run check && npm run test:unit && npm run build && npm run check:examples && npm run build:examples"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "src/lib",
    "!src/lib/**/*.test.*",
    "!src/lib/**/*.spec.*",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.27",
    "marked": "^17.0.1",
    "marked-katex-extension": "^5.1.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^24",
    "@vitest/browser-playwright": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "publint": "^0.3.17",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "vitest-browser-svelte": "^2.0.2"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chat",
    "ui",
    "svelte",
    "sveltekit",
    "markdown",
    "composer",
    "assistant",
    "components"
  ]
}
